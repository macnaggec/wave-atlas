generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  password           String?
  name               String?
  role               UserRole           @default(USER)
  balance            Int                @default(0)
  createdAt          DateTime           @default(now()) @map("created_at")
  emailVerified      Boolean            @default(false) @map("email_verified")
  image              String?
  updatedAt          DateTime           @updatedAt @map("updated_at")
  deletedAt          DateTime?          @map("deleted_at")
  externalCustomerId String?            @map("external_customer_id")
  accounts           Account[]
  mediaItems         MediaItem[]        @relation("PhotographerMedia")
  surfSessions       SurfSession[]      @relation("PhotographerSurfSessions")
  orders             Order[]
  payoutRequests     PayoutRequest[]
  purchases          Purchase[]
  sessions           Session[]
  createdSpots       Spot[]             @relation("UserCreatedSpots")
  transactions       Transaction[]
  spotCovers         UserSpotCover[]
  favoriteSpots      UserFavoriteSpot[]
  favoriteMedia      UserFavoriteMedia[]
  uploadWorkspaces   UploadWorkspace[]
  uploadWorkspaceAssets UploadWorkspaceAsset[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@map("verifications")
}

model MediaItem {
  id                 String            @id @default(uuid())
  type               MediaType         @default(PHOTO)
  sessionId          String            @map("session_id")
  photographerId     String            @map("photographer_id")
  spotId             String?           @map("spot_id")
  capturedAt         DateTime          @map("captured_at")
  price              Int?
  lightboxUrl        String            @map("lightbox_url")
  cloudinaryPublicId String            @map("cloudinary_public_id")
  status             MediaStatus       @default(DRAFT)
  deletedAt          DateTime?         @map("deleted_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  thumbnailUrl       String            @map("thumbnail_url")
  importSource       MediaImportSource @default(DIRECT) @map("import_source")
  remoteFileId       String?           @map("remote_file_id")
  photographer       User              @relation("PhotographerMedia", fields: [photographerId], references: [id])
  session            SurfSession       @relation(fields: [sessionId, photographerId], references: [id, photographerId])
  spot               Spot?             @relation(fields: [spotId], references: [id])
  orderItems         OrderItem[]
  purchases          Purchase[]
  workspaceMediaChanges UploadWorkspaceMediaChange[]
  uploadAttemptId    String?        @unique @map("upload_attempt_id")
  uploadAttempt      UploadAttempt? @relation(fields: [uploadAttemptId], references: [id])
  favoritedBy        UserFavoriteMedia[]

  @@index([sessionId], map: "media_items_session_id_idx")
  @@index([photographerId, status, deletedAt, createdAt], map: "media_items_photographer_status_deleted_created_idx")
  @@index([photographerId, status, deletedAt, capturedAt], map: "media_items_photographer_status_deleted_captured_idx")
  @@index([spotId, status, deletedAt, capturedAt], map: "media_items_spot_status_deleted_captured_idx")
  @@index([spotId, photographerId, status, deletedAt, createdAt], map: "media_items_spot_photographer_status_deleted_created_idx")
  @@map("media_items")
}

model Spot {
  id               String             @id @default(uuid())
  name             String
  location         String
  lat              Decimal?           @db.Decimal(10, 8)
  lng              Decimal?           @db.Decimal(11, 8)
  searchRadius     Int?               @map("search_radius")
  status           SpotStatus         @default(verified)
  creatorId        String?            @map("creator_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  aliases          String[]
  coverUrl         String?            @map("cover_url")
  mediaItems       MediaItem[]
  surfSessions     SurfSession[]
  uploadWorkspaces UploadWorkspace[]
  creator          User?              @relation("UserCreatedSpots", fields: [creatorId], references: [id])
  spotCovers   UserSpotCover[]
  favoritedBy      UserFavoriteSpot[]

  @@map("spots")
}

model SurfSession {
  id             String            @id @default(uuid())
  spotId         String?           @map("spot_id")
  photographerId String            @map("photographer_id")
  startsAt       DateTime?         @map("starts_at")
  endsAt         DateTime?         @map("ends_at")
  photoPrice     Int               @default(300) @map("photo_price")
  videoPrice     Int               @default(300) @map("video_price")
  status         SurfSessionStatus @default(DRAFT)
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @default(now()) @updatedAt @map("updated_at")

  spot         Spot?          @relation(fields: [spotId], references: [id])
  photographer User           @relation("PhotographerSurfSessions", fields: [photographerId], references: [id])
  mediaItems     MediaItem[]
  editWorkspaces UploadWorkspace[] @relation("TargetSessionWorkspaces")

  @@unique([id, photographerId], map: "surf_sessions_id_photographer_id_key")
  @@index([status, createdAt], map: "surf_sessions_status_created_idx")
  @@index([spotId, status, createdAt], map: "surf_sessions_spot_status_created_idx")
  @@index([photographerId, createdAt], map: "surf_sessions_photographer_created_idx")
  @@index([photographerId, status, updatedAt], map: "surf_sessions_photographer_draft_updated_idx")
  @@map("surf_sessions")
}

model UploadWorkspace {
  id              String                @id @default(uuid())
  kind            UploadWorkspaceKind
  status          UploadWorkspaceStatus @default(ACTIVE)
  photographerId  String                @map("photographer_id")
  targetSessionId String?               @map("target_session_id")
  spotId          String?               @map("spot_id")
  startsAt        DateTime?             @map("starts_at")
  endsAt          DateTime?             @map("ends_at")
  photoPrice      Int                   @default(300) @map("photo_price")
  videoPrice      Int                   @default(300) @map("video_price")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  photographer User                    @relation(fields: [photographerId], references: [id])
  targetSession SurfSession?           @relation("TargetSessionWorkspaces", fields: [targetSessionId, photographerId], references: [id, photographerId])
  spot          Spot?                  @relation(fields: [spotId], references: [id])
  attempts      UploadAttempt[]
  assets        UploadWorkspaceAsset[]
  mediaChanges  UploadWorkspaceMediaChange[]

  @@index([photographerId, status, updatedAt], map: "upload_workspaces_photographer_status_updated_idx")
  @@index([targetSessionId], map: "upload_workspaces_target_session_idx")
  @@map("upload_workspaces")
}

model UploadWorkspaceAsset {
  id                 String                     @id @default(uuid())
  workspaceId        String                     @map("workspace_id")
  photographerId     String                     @map("photographer_id")
  type               MediaType                  @default(PHOTO)
  cloudinaryPublicId String                     @unique @map("cloudinary_public_id")
  thumbnailUrl       String                     @map("thumbnail_url")
  lightboxUrl        String                     @map("lightbox_url")
  capturedAt         DateTime                   @map("captured_at")
  importSource       MediaImportSource          @default(DIRECT) @map("import_source")
  remoteFileId       String?                    @map("remote_file_id")
  status             UploadWorkspaceAssetStatus @default(READY)
  uploadAttemptId    String?                    @unique @map("upload_attempt_id")
  createdAt          DateTime                   @default(now()) @map("created_at")

  workspace    UploadWorkspace @relation(fields: [workspaceId], references: [id])
  photographer User            @relation(fields: [photographerId], references: [id])
  uploadAttempt UploadAttempt? @relation(fields: [uploadAttemptId], references: [id])

  @@index([workspaceId, status, createdAt], map: "upload_workspace_assets_workspace_status_created_idx")
  @@map("upload_workspace_assets")
}

model UploadWorkspaceMediaChange {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  mediaItemId String   @map("media_item_id")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace UploadWorkspace @relation(fields: [workspaceId], references: [id])
  mediaItem MediaItem       @relation(fields: [mediaItemId], references: [id])

  @@unique([workspaceId, mediaItemId], map: "upload_workspace_media_changes_workspace_media_key")
  @@index([mediaItemId], map: "upload_workspace_media_changes_media_item_idx")
  @@map("upload_workspace_media_changes")
}

model Order {
  id              String      @id @default(uuid())
  buyerId         String?     @map("buyer_id")
  externalOrderId String?     @unique @map("external_order_id")
  totalAmount     Int         @map("total_amount")
  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  guestEmail      String?     @map("guest_email")
  items           OrderItem[]
  buyer           User?       @relation(fields: [buyerId], references: [id])
  purchases       Purchase[]

  @@map("orders")
}

model OrderItem {
  id          String    @id @default(uuid())
  orderId     String    @map("order_id")
  mediaItemId String    @map("media_item_id")
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id])
  order       Order     @relation(fields: [orderId], references: [id])

  @@map("order_items")
}

model Purchase {
  id                 String    @id @default(uuid())
  buyerId            String?   @map("buyer_id")
  amountPaid         Int       @map("amount_paid")
  platformFee        Int       @map("platform_fee")
  photographerEarned Int       @map("photographer_earned")
  purchasedAt        DateTime  @default(now()) @map("purchased_at")
  mediaItemId        String    @map("media_item_id")
  orderId            String?   @map("order_id")
  previewUrl         String?   @map("preview_url")
  downloadToken      String?   @unique @map("download_token")
  guestEmail         String?   @map("guest_email")
  buyer              User?     @relation(fields: [buyerId], references: [id])
  mediaItem          MediaItem @relation(fields: [mediaItemId], references: [id])
  order              Order?    @relation(fields: [orderId], references: [id])

  @@map("purchases")
}

model Transaction {
  id              String            @id @default(uuid())
  userId          String            @map("user_id")
  amount          Int
  createdAt       DateTime          @default(now()) @map("created_at")
  externalOrderId String?           @map("external_order_id")
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  payoutRequest   PayoutRequest?    @relation("PayoutRequestTransaction")
  user            User              @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model PayoutRequest {
  id                 String       @id @default(uuid())
  photographerId     String       @map("photographer_id")
  transactionId      String       @unique @map("transaction_id")
  amount             Int
  status             PayoutStatus @default(PENDING)
  externalTransferId String?      @map("external_transfer_id")
  note               String?
  requestedAt        DateTime     @default(now()) @map("requested_at")
  processedAt        DateTime?    @map("processed_at")
  photographer       User         @relation(fields: [photographerId], references: [id])
  transaction        Transaction  @relation("PayoutRequestTransaction", fields: [transactionId], references: [id])

  @@map("payout_requests")
}

model UserSpotCover {
  userId    String   @map("user_id")
  spotId    String   @map("spot_id")
  imageUrl  String   @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  spot      Spot     @relation(fields: [spotId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, spotId])
  @@map("user_spot_covers")
}

model UserFavoriteSpot {
  userId    String   @map("user_id")
  spotId    String   @map("spot_id")
  createdAt DateTime @default(now()) @map("created_at")
  spot      Spot     @relation(fields: [spotId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, spotId])
  @@map("user_favorite_spots")
}

model UserFavoriteMedia {
  userId      String    @map("user_id")
  mediaItemId String    @map("media_item_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, mediaItemId])
  @@index([userId, createdAt(sort: Desc)], map: "user_favorite_media_user_created_idx")
  @@map("user_favorite_media")
}

enum SurfSessionStatus {
  DRAFT
  PUBLISHED
  DELETED
}

enum MediaType {
  PHOTO
  VIDEO
}

enum UploadSource {
  LOCAL
  DRIVE
}

enum UploadAttemptStatus {
  READY
  ACQUIRING
  FINALIZING
  COMPLETED
  FAILED
  CANCEL_REQUESTED
  CLEANUP_PENDING
  CANCELLED
}

enum UploadWorkspaceKind {
  NEW_SESSION
  SESSION_EDIT
}

enum UploadWorkspaceStatus {
  ACTIVE
  SAVED
  CANCELLED
}

enum UploadWorkspaceAssetStatus {
  READY
  PROMOTED
  CLEANUP_PENDING
  DELETED
}

enum MediaStatus {
  DRAFT
  PUBLISHED
  DELETED
  DRIVE_PENDING
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
}

enum TransactionType {
  SALE
  PAYOUT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  REJECTED
}

enum UserRole {
  USER
  ADMIN
}

enum SpotStatus {
  verified
  unverified
}

enum MediaImportSource {
  DIRECT
  GOOGLE_DRIVE
}

model UploadAttempt {
  id                   String              @id @default(uuid())
  clientRequestId      String              @map("client_request_id")
  workspaceId          String              @map("workspace_id")
  photographerId       String              @map("photographer_id")
  source               UploadSource
  status               UploadAttemptStatus @default(READY)
  cloudinaryPublicId   String              @unique @map("cloudinary_public_id")
  expectedMediaType    MediaType           @map("expected_media_type")
  remoteFileId         String?             @map("remote_file_id")
  lastErrorCode        String?             @map("last_error_code")
  uploadGrantExpiresAt DateTime?           @map("upload_grant_expires_at")
  expiresAt            DateTime            @map("expires_at")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  workspace UploadWorkspace @relation(fields: [workspaceId], references: [id])
  mediaItem MediaItem?
  workspaceAsset UploadWorkspaceAsset?

  @@unique([photographerId, clientRequestId], map: "upload_attempts_photographer_client_request_key")
  @@index([workspaceId, status], map: "upload_attempts_workspace_status_idx")
  @@index([status, expiresAt], map: "upload_attempts_status_expires_idx")
  @@map("upload_attempts")
}
