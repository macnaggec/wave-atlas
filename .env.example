# Database
DATABASE_URL="postgresql://user:password@localhost:5432/surfdb"

# App
APP_URL="http://localhost:3000"

# Better Auth
BETTER_AUTH_URL=http://localhost:3001

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Google Picker API (Google Cloud Platform API Key — restrict to "Google Picker API")
# Create at: Google Cloud Console → APIs & Services → Credentials → Create Credentials → API Key
VITE_GOOGLE_CLIENT_ID=""
VITE_GOOGLE_API_KEY=""

# Mapbox
# Get your access token at https://account.mapbox.com/access-tokens/
# NOTE: this token is exposed to browser clients. Restrict it in Mapbox to your production/staging domains.
VITE_MAPBOX_ACCESS_TOKEN="your-mapbox-token-here"

# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Payment provider (CryptoCloud) — credentials documented in .env.payments.cryptocloud
# Use 'mock' to skip CryptoCloud entirely during local development
PAYMENT_PROVIDER=mock
CRYPTOCLOUD_API_KEY=""
CRYPTOCLOUD_SHOP_ID=""
CRYPTOCLOUD_SECRET_KEY=""
