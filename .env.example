# Database
DATABASE_URL="postgresql://user:password@localhost:5432/surfdb"

# Auth.js (NextAuth)
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Mapbox
# Get your access token at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="your-mapbox-token-here"

# Optional: OAuth Providers (add when needed)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
