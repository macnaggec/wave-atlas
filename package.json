{
  "name": "wave-atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "overrides": {
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3"
  },
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,yellow \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "test": "vitest",
    "test:client": "vitest --project client",
    "test:server": "vitest --project server",
    "test:integration": "vitest --project integration",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/trpc-server": "^0.4.2",
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@mantine/carousel": "^8.3.11",
    "@mantine/core": "^8.3.1",
    "@mantine/dates": "^8.3.11",
    "@mantine/dropzone": "^8.3.11",
    "@mantine/hooks": "^8.3.1",
    "@mantine/notifications": "^8.3.11",
    "@mantine/nprogress": "^8.3.11",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@tabler/icons-react": "^3.12.0",
    "@tanstack/react-query": "^5.95.0",
    "@tanstack/react-query-devtools": "^5.95.0",
    "@tanstack/react-router": "^1.166.0",
    "@tanstack/router-devtools": "^1.166.0",
    "@tanstack/router-plugin": "^1.166.0",
    "@trpc/client": "^11.15.0",
    "@trpc/react-query": "^11.15.0",
    "@trpc/server": "^11.15.0",
    "@trpc/tanstack-react-query": "^11.15.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.6",
    "cloudinary": "^2.4.0",
    "compose-function": "^3.0.3",
    "dayjs": "^1.11.19",
    "embla-carousel-react": "^8.6.0",
    "exifr": "^7.1.3",
    "hls.js": "^1.5.15",
    "hono": "^4.7.7",
    "mapbox-gl": "^3.9.4",
    "pg": "^8.16.3",
    "prisma": "^7.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-map-gl": "^7.1.9",
    "superjson": "^2.2.6",
    "swr": "^2.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compose-function": "^0.0.33",
    "@types/node": "20.19.0",
    "@types/pg": "^8.16.0",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "chrome-remote-interface": "^0.34.0",
    "concurrently": "^9.1.2",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.41",
    "postcss-loader": "^8.1.1",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.17",
    "vitest-mock-extended": "^3.1.0"
  }
}
